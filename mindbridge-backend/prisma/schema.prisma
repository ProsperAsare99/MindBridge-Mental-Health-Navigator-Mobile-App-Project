generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String             @id @default(uuid())
  email             String             @unique
  password          String
  name              String
  studentId         String?
  phoneNumber       String?
  profileImage      String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  username          String?            @unique
  assessmentResults AssessmentResult[]
  chatMessages      ChatMessage[]
  communityPosts    CommunityPost[]
  journalEntries    Journal[]
  moodLogs          MoodLog[]
  onboarding        Onboarding?
}

model Onboarding {
  id                    String   @id @default(uuid())
  userId                String   @unique
  firstName             String?
  university            String?
  program               String?
  level                 String?
  preferredLanguage     String?
  communicationStyle    String?
  spiritualBackground   String?
  interests             String[]
  currentAcademicSeason String?
  primaryGoals          String[]
  currentMood           String
  sleepPattern          String
  stressLevel           Int
  completedAt           DateTime @default(now())
  stressSources         String[]
  supportTypes          String[]
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MoodLog {
  id               String   @id @default(uuid())
  userId           String
  score            Int
  emotions         String[]
  energyLevel      Int?
  sleepHours       Float?
  sleepQuality     String?
  socialSetting    String?
  physicalSymptoms String[]
  weather          String?
  location         String?
  audioUrl         String?
  note             String?
  steps            Int?
  facialMetrics    Json?
  createdAt        DateTime @default(now())
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Journal {
  id        String   @id @default(uuid())
  userId    String
  title     String?
  content   String
  mood      String?
  audioUrl  String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CommunityPost {
  id        String   @id @default(uuid())
  userId    String
  group     String
  content   String
  hugs      Int      @default(0)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AssessmentResult {
  id        String   @id @default(uuid())
  userId    String
  type      String
  score     Int
  severity  String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Resource {
  id        String   @id @default(uuid())
  title     String
  type      String
  category  String?
  duration  String?
  author    String?
  url       String?
  color     String?
  createdAt DateTime @default(now())
}

model ChatMessage {
  id        String   @id @default(uuid())
  userId    String
  role      String
  content   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
